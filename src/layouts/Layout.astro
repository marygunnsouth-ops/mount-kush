---
// Layout.astro — Mount Kush base layout
import WelcomePopup from '../components/WelcomePopup.astro';
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}
const {
  title = 'Mount Kush | Cannabis Lifestyle Store Johannesburg',
  description = 'Mount Kush is Johannesburg\'s premium cannabis lifestyle store. Three locations: Blackheath, Allens Nek & Berario. Order via WhatsApp.',
  ogImage = '/images/hero.png',
  noIndex = false,
} = Astro.props;
const canon = new URL(Astro.url.pathname, Astro.site);
const WA_NUMBER = '27639260217';
const WA_MSG = encodeURIComponent("Hi Mount Kush! I'd like to place an order 🌿");
const WA_LINK = `https://wa.me/${WA_NUMBER}?text=${WA_MSG}`;
---
<!DOCTYPE html>
<html lang="en-ZA">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content={description}/>
  <link rel="canonical" href={canon}/>
  {noIndex && <meta name="robots" content="noindex,nofollow"/>}
  <meta property="og:type" content="website"/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image" content={new URL(ogImage, Astro.site)}/>
  <meta name="twitter:card" content="summary_large_image"/>
  <link rel="icon" type="image/png" href="/images/logo.png"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <title>{title}</title>
</head>
<body>

  <!-- ══ WELCOME POPUP ════════════════════════════════════ -->
  <WelcomePopup />

  <!-- ══ NAVIGATION ════════════════════════════════════════ -->
  <nav class="site-nav" id="site-nav">
    <div class="container">
      <div class="nav-inner">
        <a href="/" class="nav-logo" aria-label="Mount Kush Home">
          <img src="/images/logo.png" alt="Mount Kush"/>
        </a>

        <div class="nav-links" id="nav-links">
          <a href="/" class="active">Home</a>
          <a href="/about">About</a>
          <a href="/products">Products</a>
          <a href="/community">Culture</a>
          <a href="/articles">Journal</a>
          <a href="/stores" class="stores-link">📍 Our Stores</a>
          <a href="/contact">Contact</a>
        </div>

        <div class="nav-cta-desktop" style="display:flex; align-items:center;">
          <a href={WA_LINK} target="_blank" rel="noopener" class="btn btn-whatsapp btn-sm">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Order Now
          </a>
        </div>

        <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
          <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- ══ PAGE CONTENT ══════════════════════════════════════ -->
  <main id="main">
    <slot/>
  </main>

  <!-- ══ FOOTER ════════════════════════════════════════════ -->
  <div class="rasta-bar"></div>

  <div class="legal-banner">
    <div class="container">
      <strong>Adults Only.</strong> Mount Kush products are sold for adult use only. You must be 18+ to purchase. Products sold in compliance with applicable South African law. <strong>For enquiries: 063 926 0217</strong>
    </div>
  </div>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <img src="/images/logo.png" alt="Mount Kush" class="footer-brand-logo"/>
          <p>Johannesburg's premium cannabis lifestyle store. Three locations across the city. High on Healing.</p>
          <div style="margin-top:1.25rem; display:flex; gap:0.75rem; flex-wrap:wrap; align-items:center;">
            <span class="age-badge">🔞 18+ Only</span>
            <span class="age-badge" style="border-color:rgba(34,197,94,0.3); background:rgba(34,197,94,0.08); color:#86efac;">POPIA Compliant</span>
          </div>
        </div>

        <div class="footer-col">
          <h4>Navigate</h4>
          <ul class="footer-links">
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/products">Products</a></li>
            <li><a href="/community">Culture</a></li>
            <li><a href="/stores">Our Stores</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Our Stores</h4>
          <ul class="footer-links">
            <li><a href="/stores#blackheath">Blackheath</a></li>
            <li><a href="/stores#allens-nek">Allens Nek</a></li>
            <li><a href="/stores#berario">Berario</a></li>
          </ul>
          <div style="margin-top:1.25rem;">
            <a href={WA_LINK} target="_blank" rel="noopener"
               style="font-size:0.9rem; color:#25D366; font-weight:600;">
              📱 063 926 0217
            </a>
          </div>
        </div>

        <div class="footer-col">
          <h4>Legal</h4>
          <ul class="footer-links">
            <li><a href="/terms">Terms & Conditions</a></li>
            <li><a href="/privacy">Privacy Policy</a></li>
            <li><a href="/responsible-use">Responsible Use</a></li>
            <li><a href="/section-21-approval">Section 21 Approval</a></li>
          </ul>
          <div style="margin-top:1.5rem; padding-top:1.25rem; border-top:1px solid rgba(255,255,255,0.07);">
            <p style="font-size:0.82rem; color:rgba(255,255,255,0.45); line-height:1.7; margin-bottom:0.6rem;">
              Welcome to Mount Kush. Access to Mount Kush is intended for persons 18 years and older.
            </p>
            <p style="font-size:0.82rem; color:rgba(255,255,255,0.45); line-height:1.7; margin-bottom:1rem;">
              SAPHRA Section 21 authorisation may support access to regulated medical cannabis pathways and recognised collection points where applicable.
            </p>
            <a
              href="https://hub.synergywellness.co.za/welcome?store=Mount+Kush+Randburg"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-gold btn-sm"
              style="display:inline-flex; width:100%; justify-content:center;"
            >
              Register Now
            </a>
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Mount Kush. All rights reserved. 🌿 High on Healing.</p>
        <div class="footer-legal">
          <a href="/terms">Terms</a>
          <a href="/privacy">Privacy</a>
          <a href="/responsible-use">Responsible Use</a>
          <a href="/section-21-approval">Section 21</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- ══ WHATSAPP FLOAT ════════════════════════════════════ -->
  <a href={WA_LINK} target="_blank" rel="noopener noreferrer"
     class="whatsapp-float" aria-label="Order via WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <script>
    // ── Nav scroll ─────────────────────────────────────────
    const nav = document.getElementById('site-nav');
    const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 40);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // ── Mobile nav toggle ──────────────────────────────────
    document.getElementById('nav-toggle')?.addEventListener('click', () => {
      nav?.classList.toggle('nav-mobile-open');
    });
  </script>

  <style is:global>
    @import '../styles/global.css';
  </style>
</body>
</html>
