---
// products.astro
import Layout from '../layouts/Layout.astro';
const WA = 'https://wa.me/27639260217?text=' + encodeURIComponent("Hi Mount Kush! I'd like to enquire about your products 🌿");

const products = [
  { cat: "Lifestyle", tag: "Lifestyle", name: "Indoor Bud", desc: "Club Members Only - various. Ask about current stock.", image: "/images/Indoor Bud.png" },
  { cat: "Accessories", tag: "Accessories", name: "Rolling Papers & Tips", desc: "King size, regular, flavoured and organic options from top brands." },
  { cat: "Accessories", tag: "Accessories", name: "Glass Pieces", desc: "Bongs, pipes, one-hitters and hand pipes. Curated selection for every preference." },
  { cat: "Accessories", tag: "Accessories", name: "Vaporizers", desc: "Dry herb vaporizers for clean, efficient sessions. Multiple brands and price points." },
  { cat: "Lifestyle", tag: "Lifestyle", name: "Rolling Trays", desc: "Branded and unbranded rolling trays in various sizes. Keep your setup clean." },
  { cat: "Lifestyle", tag: "Lifestyle", name: "Storage Solutions", desc: "Airtight storage jars, smell-proof bags and herb containers." },
  { cat: "Lifestyle", tag: "Lifestyle", name: "Lighters & Torches", desc: "Windproof lighters, jet torches and accessories for every setup." },
  { cat: "Lifestyle", tag: "Lifestyle", name: "Cleaning Kits", desc: "Keep your pieces in top condition with our range of cleaning products and tools." },
  { cat: "Merchandise", tag: "Merch", name: "Mount Kush Hoodies", desc: "Premium fleece hoodies with the iconic Mount Kush Yeti design. Warm, comfortable, cultural." },
  { cat: "Merchandise", tag: "Merch", name: "Branded T-Shirts", desc: "Soft cotton tees with Mount Kush designs. Multiple colourways. Ask about current drops." },
  { cat: "Merchandise", tag: "Merch", name: "Caps & Beanies", desc: "Headwear for the culture. Embroidered Mount Kush branding." },
  { cat: "Merchandise", tag: "Merch", name: "Limited Drops", desc: "Special edition and limited release items. Check with us on WhatsApp for what's currently available." },
];
---
<Layout
  title="Products | Mount Kush Cannabis Lifestyle Store Johannesburg"
  description="Browse Mount Kush's range of cannabis accessories, lifestyle gear and branded merchandise. Order via WhatsApp."
>
  <section class="page-hero">
    <div class="container">
      <div class="section-eyebrow">Our Range</div>
      <h1 class="display-lg" style="margin-bottom:1rem;">Products</h1>
      <p class="lead">Accessories, lifestyle gear and Mount Kush merchandise. Browse below and order via WhatsApp.</p>
    </div>
  </section>

  <section class="section" style="background:var(--purple-deep);">
    <div class="container">
      <!-- Category tabs -->
      <div style="display:flex; gap:0.75rem; flex-wrap:wrap; margin-bottom:3rem;" id="cat-filter">
        {["All", "Accessories", "Lifestyle", "Merchandise"].map(cat => (
          <button data-cat={cat} class={`btn btn-sm ${cat === 'All' ? 'btn-gold' : 'btn-outline-gold'}`} onclick="filterCat(this)">
            {cat}
          </button>
        ))}
      </div>

      <div class="grid-3" id="products-grid">
        {products.map(p => (
          <div class="card" data-category={p.cat}>
 {p.image ? (
  <img src={p.image} alt={p.name} class="card-img" />
) : (
  <div class="card-img-placeholder">
    No image available
  </div>
)}
            <div class="card-body">
              <span class="card-tag">{p.tag}</span>
              <div class="card-title">{p.name}</div>
              <p class="card-text">{p.desc}</p>
              <a href={`https://wa.me/27639260217?text=${encodeURIComponent(`Hi Mount Kush! I'd like to order: ${p.name} 🌿`)}`}
                 target="_blank" rel="noopener" class="btn btn-whatsapp btn-sm">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                Order via WhatsApp
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
function filterCat(btn) {
  const cat = btn.dataset.cat;
  document.querySelectorAll('#cat-filter button').forEach(b => {
    b.className = 'btn btn-sm btn-outline-gold';
  });
  btn.className = 'btn btn-sm btn-gold';
  document.querySelectorAll('#products-grid .card').forEach(card => {
    card.style.display = (cat === 'All' || card.dataset.category === cat) ? '' : 'none';
  });
}
</script>
