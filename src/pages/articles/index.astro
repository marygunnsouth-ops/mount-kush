---
import Layout from '../../layouts/Layout.astro';
import { articles } from '../../data/articles.js';
---
<Layout
  title="The Mount Kush Journal | Cannabis Education, Wellness & Lifestyle"
  description="Articles on cannabis wellness, responsible adult use, South African compliance, and lifestyle culture from Mount Kush — Johannesburg's premier cannabis lifestyle store."
>

  <!-- ══ PAGE HERO ══════════════════════════════════════════ -->
  <section class="page-hero">
    <div class="container">
      <div class="section-eyebrow">Knowledge & Culture</div>
      <h1 class="display-md">The Mount Kush<br/><span style="color:var(--gold-bright);">Journal</span></h1>
      <p class="lead" style="margin-top:1rem;">
        Cannabis education, wellness insights, lifestyle culture and compliance guidance —
        written for curious, informed adults.
      </p>
    </div>
  </section>

  <!-- ══ ARTICLES GRID ══════════════════════════════════════ -->
  <section class="section section--deep">
    <div class="container">

      <div class="grid-3">
        {articles.map((article) => (
          <a href={`/articles/${article.slug}`} class="card article-card-link">
            {article.image ? (
              <img src={article.image} alt={article.title} class="card-img" loading="lazy"/>
            ) : (
              <div class="card-img-placeholder">Mount Kush Journal</div>
            )}
            <div class="card-body">
              <span class="card-tag">{article.tag}</span>
              <div class="card-title">{article.title}</div>
              <p class="card-text">{article.excerpt}</p>
              <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:0.5rem;">
                <span style="font-size:0.78rem; color:rgba(255,255,255,0.35); letter-spacing:0.05em;">{article.date}</span>
                <span class="btn btn-outline-gold btn-sm">Read Article →</span>
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</Layout>

<style>
  .article-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .article-card-link .btn {
    pointer-events: none;
  }
</style>
