---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Thank You | Mount Kush" description="Thank you for signing up to Kush Rewards." noIndex={true}>
  <section style="min-height:80vh; display:flex; align-items:center; justify-content:center; text-align:center; padding:4rem 2rem;">
    <div>
      <div style="font-size:4rem; margin-bottom:1.5rem;">🌿</div>
      <h1 class="display-md" style="margin-bottom:1rem; color:var(--gold-bright);">You're In!</h1>
      <p class="lead" style="margin:0 auto; max-width:480px;">Welcome to Kush Rewards. You'll start earning on your next purchase. See you in store.</p>
      <div style="margin-top:2.5rem; display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/" class="btn btn-gold btn-lg">Back to Home</a>
        <a href="/stores" class="btn btn-outline-gold btn-lg">Find a Store</a>
      </div>
    </div>
  </section>
</Layout>
