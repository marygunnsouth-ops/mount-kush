---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found | Mount Kush" description="Page not found." noIndex={true}>
  <section style="min-height:80vh; display:flex; align-items:center; justify-content:center; text-align:center; padding:4rem 2rem;">
    <div>
      <div style="font-size:5rem; font-family:var(--font-display); letter-spacing:0.05em; color:var(--gold-bright); line-height:1;">404</div>
      <p style="font-size:1.1rem; color:rgba(255,255,255,0.55); margin:1rem 0 2.5rem;">Looks like this page got lost in the smoke.</p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/" class="btn btn-gold btn-lg">Back to Home</a>
        <a href="/stores" class="btn btn-outline-gold btn-lg">Find a Store</a>
      </div>
    </div>
  </section>
</Layout>
