---
import Layout from '../layouts/Layout.astro';
const WA_LINK = 'https://wa.me/27639260217?text=' + encodeURIComponent("Hi Mount Kush! I'd like to get in touch 🌿");
---
<Layout title="Contact Mount Kush | WhatsApp 063 926 0217 | Johannesburg" description="Contact Mount Kush cannabis lifestyle store. WhatsApp or call us on 063 926 0217. Three store locations in Johannesburg: Blackheath, Allens Nek and Berario.">

  <section class="page-hero">
    <div class="container">
      <div class="section-eyebrow">Get in Touch</div>
      <h1 class="display-lg" style="margin-bottom:1rem;">Contact</h1>
      <p class="lead">We're always available on WhatsApp. One number for all three stores.</p>
    </div>
  </section>

  <section class="section" style="background:var(--purple-deep);">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:start; max-width:900px; margin:0 auto;">

        <!-- Primary contact -->
        <div>
          <div class="section-eyebrow">Primary Contact</div>
          <h2 class="display-md" style="margin-bottom:2rem;">063 926 0217</h2>

          <div style="display:flex; flex-direction:column; gap:1.5rem;">
            <div style="background:rgba(37,211,102,0.08); border:1px solid rgba(37,211,102,0.25); border-radius:var(--radius-lg); padding:2rem;">
              <div style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.14em; color:#86efac; margin-bottom:0.5rem;">WhatsApp — Preferred</div>
              <p style="font-size:0.95rem; color:rgba(255,255,255,0.65); margin-bottom:1.25rem;">Message us on WhatsApp to place orders, check stock, or ask any questions. We respond fast.</p>
              <a href={WA_LINK} target="_blank" rel="noopener" class="btn btn-whatsapp" style="width:100%; justify-content:center;">
                <svg viewBox="0 0 24 24" fill="currentColor" style="width:20px;height:20px"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                Message on WhatsApp
              </a>
            </div>

            <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(212,160,23,0.15); border-radius:var(--radius-lg); padding:2rem;">
              <div style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.14em; color:var(--gold); margin-bottom:0.5rem;">Call Us</div>
              <p style="font-size:0.95rem; color:rgba(255,255,255,0.65); margin-bottom:1.25rem;">Prefer to speak to us? Call the same number during store hours.</p>
              <a href="tel:0639260217" class="btn btn-outline-gold" style="width:100%; justify-content:center;">
                📞 063 926 0217
              </a>
            </div>
          </div>
        </div>

        <!-- Store quick links -->
        <div>
          <div class="section-eyebrow">Store Locations</div>
          <h2 class="display-md" style="margin-bottom:2rem;">Our Stores</h2>
          <div style="display:flex; flex-direction:column; gap:1rem;">
            {[
              {
                name: "Blackheath",
                addr: "311 Pendoring Road, Blackheath",
                msg: "Hi! Calling from Blackheath area 🌿",
                hours: [
                  "Mon–Thu: 08:30–19:00",
                  "Fri–Sat: 08:30–20:00",
                  "Sun: 08:30–16:00",
                ]
              },
              {
                name: "Allens Nek",
                addr: "72 Rinyani Avenue, Weltevredenpark, Roodepoort",
                msg: "Hi! Calling from Allens Nek area 🌿",
                hours: [
                  "Mon–Thu: 09:00–19:00",
                  "Fri–Sat: 09:00–20:00",
                  "Sun: 09:00–18:00",
                ]
              },
              {
                name: "Berario",
                addr: "Shop 8, Arkansas Avenue, Berario, Randburg",
                msg: "Hi! Calling from Berario area 🌿",
                hours: [
                  "Mon–Thu: 09:00–19:00",
                  "Fri–Sat: 09:00–20:00",
                  "Sun: 09:00–18:00",
                ]
              },
            ].map(s => (
              <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(212,160,23,0.15); border-radius:var(--radius); padding:1.25rem 1.5rem;">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; flex-wrap:wrap; margin-bottom:0.75rem;">
                  <div>
                    <div style="font-weight:700; color:var(--gold-bright); font-size:1rem;">{s.name}</div>
                    <div style="font-size:0.85rem; color:rgba(255,255,255,0.5); margin-top:0.2rem;">{s.addr}</div>
                  </div>
                  <a href={`https://wa.me/27639260217?text=${encodeURIComponent(s.msg)}`} target="_blank" rel="noopener"
                     class="btn btn-whatsapp btn-sm" style="white-space:nowrap; flex-shrink:0;">
                    Order
                  </a>
                </div>
                <div style="display:flex; flex-direction:column; gap:0.2rem; border-top:1px solid rgba(255,255,255,0.07); padding-top:0.65rem;">
                  {s.hours.map(h => (
                    <div style="font-size:0.8rem; color:rgba(255,255,255,0.45);">🕐 {h}</div>
                  ))}
                </div>
              </div>
            ))}
          </div>
          <div style="margin-top:1.5rem;">
            <a href="/stores" class="btn btn-outline-gold" style="width:100%; justify-content:center;">
              View Full Store Details & Maps →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  @media (max-width:768px) {
    div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; }
  }
</style>
